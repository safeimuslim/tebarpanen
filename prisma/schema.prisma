generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String   @default("") @map("password")
  role         UserRole @default(WORKER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Pond {
  id        String         @id @default(cuid())
  name      String
  code      String         @unique
  type      PondType
  lengthM   Float?
  widthM    Float?
  depthM    Float?
  capacity  Int?
  status    PondStatus     @default(ACTIVE)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  cycles    CultureCycle[]
}

model CultureCycle {
  id                String         @id @default(cuid())
  pondId            String
  pond              Pond           @relation(fields: [pondId], references: [id], onDelete: Cascade)
  cycleName         String
  startDate         DateTime
  endDate           DateTime?
  seedCount         Int
  initialAvgWeightG Float?
  targetHarvestDate DateTime?
  status            CycleStatus    @default(ACTIVE)
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  feedLogs          FeedLog[]
  mortalityLogs     MortalityLog[]
}

model FeedLog {
  id             String       @id @default(cuid())
  cultureCycleId String
  cultureCycle   CultureCycle @relation(fields: [cultureCycleId], references: [id], onDelete: Cascade)
  logDate        DateTime
  feedName       String
  quantityKg     Float
  priceTotal     Decimal?     @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model MortalityLog {
  id             String       @id @default(cuid())
  cultureCycleId String
  cultureCycle   CultureCycle @relation(fields: [cultureCycleId], references: [id], onDelete: Cascade)
  logDate        DateTime
  deadCount      Int
  cause          String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum PondType {
  TERPAL
  BETON
  TANAH
}

enum PondStatus {
  ACTIVE
  EMPTY
  MAINTENANCE
}

enum CycleStatus {
  ACTIVE
  HARVESTED
  FAILED
  CLOSED
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  WORKER
}
