generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String   @default("") @map("password")
  role         UserRole @default(WORKER)
  isActive     Boolean  @default(true)
  farmId       String?
  farm         Farm?    @relation("FarmMembers", fields: [farmId], references: [id], onDelete: SetNull)
  managedFarm  Farm?    @relation("FarmManager")
  createdById  String?
  createdBy    User?    @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[]   @relation("UserCreatedBy")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Farm {
  id          String         @id @default(cuid())
  name        String
  description String?
  managerId   String         @unique
  manager     User           @relation("FarmManager", fields: [managerId], references: [id], onDelete: Cascade)
  users       User[]         @relation("FarmMembers")
  ponds       Pond[]
  equipment   Equipment[]
  cycles      CultureCycle[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Pond {
  id                 String      @id @default(cuid())
  farmId             String?
  farm               Farm?       @relation(fields: [farmId], references: [id], onDelete: SetNull)
  name               String
  code               String      @unique
  type               PondType
  shape              PondShape   @default(RECTANGLE)
  lengthM            Float?
  widthM             Float?
  diameterM          Float?
  depthM             Float?
  capacity           Int?
  purchasePrice      Decimal?    @db.Decimal(14, 2)
  installedAt        DateTime?
  depreciationMonths Int?
  status             PondStatus  @default(ACTIVE)
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  cyclePonds         CyclePond[]
}

model Equipment {
  id                 String             @id @default(cuid())
  farmId             String?
  farm               Farm?              @relation(fields: [farmId], references: [id], onDelete: SetNull)
  name               String
  type               EquipmentType
  quantity           Int                @default(1)
  brand              String?
  serialNumber       String?
  calibrationDate    DateTime?
  condition          EquipmentCondition @default(READY)
  purchasePrice      Decimal?           @db.Decimal(14, 2)
  purchasedAt        DateTime?
  depreciationMonths Int?
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model CultureCycle {
  id                String            @id @default(cuid())
  farmId            String?
  farm              Farm?             @relation(fields: [farmId], references: [id], onDelete: SetNull)
  cycleName         String
  startDate         DateTime
  endDate           DateTime?
  seedCount         Int
  initialAvgWeightG Float?
  seedPriceTotal    Decimal?          @db.Decimal(14, 2)
  targetHarvestDate DateTime?
  status            CycleStatus       @default(ACTIVE)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  ponds             CyclePond[]
  feedLogs          FeedLog[]
  expenseLogs       ExpenseLog[]
  mortalityLogs     MortalityLog[]
  samplingLogs      SamplingLog[]
  treatmentLogs     TreatmentLog[]
  waterQualityLogs  WaterQualityLog[]
}

model CyclePond {
  cycleId   String
  pondId    String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  cycle     CultureCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  pond      Pond         @relation(fields: [pondId], references: [id], onDelete: Cascade)

  @@id([cycleId, pondId])
  @@index([pondId])
}

model FeedLog {
  id             String       @id @default(cuid())
  cultureCycleId String
  cultureCycle   CultureCycle @relation(fields: [cultureCycleId], references: [id], onDelete: Cascade)
  logDate        DateTime
  feedName       String
  quantityKg     Float
  priceTotal     Decimal?     @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model MortalityLog {
  id             String       @id @default(cuid())
  cultureCycleId String
  cultureCycle   CultureCycle @relation(fields: [cultureCycleId], references: [id], onDelete: Cascade)
  logDate        DateTime
  deadCount      Int
  cause          String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SamplingLog {
  id              String       @id @default(cuid())
  cultureCycleId  String
  cultureCycle    CultureCycle @relation(fields: [cultureCycleId], references: [id], onDelete: Cascade)
  logDate         DateTime
  sampleCount     Int
  averageWeightG  Float?
  averageLengthCm Float?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model WaterQualityLog {
  id             String       @id @default(cuid())
  cultureCycleId String
  cultureCycle   CultureCycle @relation(fields: [cultureCycleId], references: [id], onDelete: Cascade)
  logDate        DateTime
  ph             Float?
  temperatureC   Float?
  doMgL          Float?
  ammoniaMgL     Float?
  waterColor     String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model TreatmentLog {
  id             String       @id @default(cuid())
  cultureCycleId String
  cultureCycle   CultureCycle @relation(fields: [cultureCycleId], references: [id], onDelete: Cascade)
  logDate        DateTime
  productName    String
  dosage         String?
  purpose        String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ExpenseLog {
  id             String          @id @default(cuid())
  cultureCycleId String
  cultureCycle   CultureCycle    @relation(fields: [cultureCycleId], references: [id], onDelete: Cascade)
  logDate        DateTime
  category       ExpenseCategory
  title          String
  amount         Decimal         @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum PondType {
  TERPAL
  BETON
  TANAH
}

enum PondShape {
  RECTANGLE
  CIRCLE
  IRREGULAR
}

enum PondStatus {
  ACTIVE
  EMPTY
  MAINTENANCE
}

enum EquipmentType {
  WATER_QUALITY_METER
  SCALE
  HARVEST_EQUIPMENT
  FEED_EQUIPMENT
  AERATION_OXYGEN
  PUMP_CIRCULATION
  CONTAINER_STORAGE
  CLEANING_EQUIPMENT
  OTHER
}

enum EquipmentCondition {
  READY
  NEEDS_CHECK
  BROKEN
}

enum CycleStatus {
  ACTIVE
  HARVESTED
  FAILED
  CLOSED
}

enum ExpenseCategory {
  SEED
  FEED
  MEDICINE_VITAMIN
  LABOR
  ELECTRICITY
  OTHER
}

enum UserRole {
  SUPER_ADMIN
  FARM_ADMIN
  WORKER
}
